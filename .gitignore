cat > .gitignore <<'EOF'
# --- Python ---
__pycache__/
*.py[cod]
*.so
*.dylib
*.egg-info/
dist/
build/

# --- Virtual environments ---
.venv/
venv/
.venv_sbi/
.venv_sbi*/

# --- OS / editor ---
.DS_Store
.vscode/

# --- Generated outputs / logs ---
models_out/
plots/
data_out/
results/
runs/
wandb/
sbi-logs/
paper/

# --- Large data artifacts (keep code in data/ tracked) ---
data/*.h5
data/*.npy
data/*.npz
data/*.zip

# --- ML artifacts ---
*.tfevents.*
*.ckpt
*.pth
*.pt
*.keras
EOF
# --- Safe publish ignore rules ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.idea/
models_out*/
plots*/
figures/
figures*/
data_out
data_out*/
results*/
paper_packet*
*.log
*.h5
*.npy
*.npz
*.zip
